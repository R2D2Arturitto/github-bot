name: GitHub Bot Without AI

on:
  issue_comment:
    types: [created]

permissions:
  issues: write

jobs:
  reply-bot:
    runs-on: ubuntu-latest

    steps:
      - name: Reply to commands
        uses: actions/github-script@v7
        with:
          script: |
            const comment = context.payload.comment.body.trim().toLowerCase();
            const issueNumber = context.payload.issue.number;
            const owner = context.repo.owner;
            const repo = context.repo.repo;
            const author = context.payload.comment.user.login;

            let reply = null;

            if (comment === '/help') {
              reply = `Cześć @${author} 👋

Dostępne komendy:
- /help
- /hello
- /status
- /zamknij`;
            } else if (comment === '/hello') {
              reply = `Cześć @${author} 👋 Bot działa poprawnie.`;
            } else if (comment === '/status') {
              reply = `@${author} Repozytorium działa, workflow został uruchomiony poprawnie.`;
            } else if (comment === '/zamknij') {
              reply = `@${author} Zamykam issue.`;

              await github.rest.issues.createComment({
                owner,
                repo,
                issue_number: issueNumber,
                body: reply
              });

              await github.rest.issues.update({
                owner,
                repo,
                issue_number: issueNumber,
                state: 'closed'
              });

              return;
            }

            if (reply) {
              await github.rest.issues.createComment({
                owner,
                repo,
                issue_number: issueNumber,
                body: reply
              });
            }
